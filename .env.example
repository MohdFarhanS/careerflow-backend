APP_NAME=Laravel
APP_ENV=local
# APP_KEY: WAJIB di-generate per environment — jalankan `php artisan key:generate`
# saat setup lokal, dan set sebagai environment variable di production.
# JANGAN commit / isi value asli di file ini; biarkan kosong sebagai template.
APP_KEY=
# APP_DEBUG: WAJIB `false` di production. Bila `true`, Whoops membocorkan stack
# trace, query SQL, dan kredensial (APP_KEY/DB_PASSWORD) pada setiap error 500.
# Nilai `true` di bawah hanya untuk development lokal.
APP_DEBUG=true
# APP_URL: di production set ke origin backend Railway (mis. https://careerflow-api.up.railway.app).
# Dipakai DocumentResource untuk membentuk URL file (`{APP_URL}/storage/...`) — jika salah, link CV 404.
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# Production MySQL (Railway MySQL addon) — set di Railway Variables, JANGAN commit value asli:
#   DB_CONNECTION=mysql
#   DB_URL=${{ MySQL.MYSQL_URL }}     # reference variable Railway (mysql://user:pass@host:port/db)
#   # atau isi manual: DB_HOST / DB_PORT / DB_DATABASE / DB_USERNAME / DB_PASSWORD dari service MySQL
# Catatan: SESSION_DRIVER=database (di bawah) → sesi ikut tersimpan di MySQL persisten.

# --- Sanctum & CORS ---
# Dev: isi keduanya. Production: isi FRONTEND_URL saja, hapus FRONTEND_URL_LOCAL.
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_LOCAL=http://localhost:3000
# Contoh PRODUCTION (set di Railway Variables — JANGAN isi value asli di file ini):
#   SANCTUM_STATEFUL_DOMAINS=careerflow.vercel.app   # TANPA https://, pisah koma jika >1 domain
#   FRONTEND_URL=https://careerflow.vercel.app        # DENGAN https:// (dipakai header CORS)
#   # kosongkan/hapus FRONTEND_URL_LOCAL → array_filter di config/cors.php membuangnya otomatis

# --- Session ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production cross-domain (FE Vercel <-> BE Railway pada domain BERBEDA):
#   SESSION_SECURE_COOKIE=true   # WAJIB — SameSite=none hanya berlaku pada koneksi Secure/HTTPS
#   SESSION_SAME_SITE=none       # WAJIB 'none' (BUKAN 'lax') agar cookie sesi terkirim cross-site
#   SESSION_DOMAIN=null          # domain FE != BE → biarkan null
# Alternatif lebih kuat — custom domain satu parent (mis. app. & api.careerflow.com):
#   SESSION_SAME_SITE=lax
#   SESSION_DOMAIN=.careerflow.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@careerflow.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
